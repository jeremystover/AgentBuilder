{
  "manifest_version": 3,
  "name": "WF Check Extractor",
  "version": "1.0.0",
  "description": "Extract check images from Wells Fargo online banking and upload payee info to the CFO agent.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://connect.secure.wellsfargo.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://connect.secure.wellsfargo.com/accounts/inquiry/accountdetails/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WF Check Extractor"
  }
}
