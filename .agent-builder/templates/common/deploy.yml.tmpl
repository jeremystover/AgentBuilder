name: Deploy __AGENT_ID__

# Generated by `pnpm create-agent`. Delegates to the reusable workflow at
# .github/workflows/_deploy-agent.yml. Set CLOUDFLARE_API_TOKEN and
# CLOUDFLARE_ACCOUNT_ID in repository secrets before the first push.
#
# If this agent uses D1, set `d1_database` below to the database_name
# from apps/__AGENT_ID__/wrangler.toml. Leave empty ('') to skip
# migrations. Migrations live in apps/__AGENT_ID__/migrations/.

on:
  push:
    branches: [main]
    paths:
      - 'apps/__AGENT_ID__/**'
      - 'packages/**'
      - 'pnpm-lock.yaml'
      - '.github/workflows/deploy-__AGENT_ID__.yml'
      - '.github/workflows/_deploy-agent.yml'
  workflow_dispatch:

jobs:
  deploy:
    uses: ./.github/workflows/_deploy-agent.yml
    with:
      agent_id: __AGENT_ID__
      d1_database: __AGENT_D1_DATABASE__
    secrets:
      CLOUDFLARE_API_TOKEN: ${{ secrets.CLOUDFLARE_API_TOKEN }}
      CLOUDFLARE_ACCOUNT_ID: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
