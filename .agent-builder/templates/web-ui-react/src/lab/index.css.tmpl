@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  html, body, #root { height: 100%; }
  body {
    background: theme(colors.bg.primary);
    color: theme(colors.text.primary);
    -webkit-font-smoothing: antialiased;
  }
  ::selection { background: theme(colors.accent.primary); color: white; }
}
