/**
 * __AGENT_NAME__ — app-agent Worker entrypoint.
 *
 * Serves static assets from ./public AND exposes a JSON API at /api/*
 * backed by the Durable Object. Good fit for admin consoles and
 * customer-facing apps.
 */

import type { Env } from '../worker-configuration';
export { __AGENT_CLASS__DO } from './durable-object.js';

export default {
  async fetch(request: Request, env: Env): Promise<Response> {
    const url = new URL(request.url);

    if (url.pathname === '/health') {
      return Response.json({ status: 'ok', agent: '__AGENT_ID__' });
    }

    if (url.pathname.startsWith('/api/')) {
      const id = env.AGENT_DO.idFromName('global');
      const stub = env.AGENT_DO.get(id);
      return stub.fetch(request);
    }

    // Everything else is static UI.
    return env.ASSETS.fetch(request);
  },
} satisfies ExportedHandler<Env>;
