name = "__AGENT_ID__"
main = "src/index.ts"
compatibility_date = "2025-04-01"
compatibility_flags = ["nodejs_compat"]

[assets]
directory = "./public"
binding = "ASSETS"

[[durable_objects.bindings]]
name = "AGENT_DO"
class_name = "__AGENT_CLASS__DO"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["__AGENT_CLASS__DO"]

[ai]
binding = "AI"

# Required if this agent has a `[triggers] crons = [...]` block — uncomment
# so cron runs land in the fleet observability tables read by the
# /dashboard UI on agent-builder. See AGENTS.md rule 11.
# [[d1_databases]]
# binding = "AGENTBUILDER_CORE_DB"
# database_name = "agentbuilder-core"
# database_id = "51a422d2-e9ea-46e8-b6c8-233229434eca"

# Add cron expressions here once the agent has scheduled work. Each entry
# must also be (a) handled in src/index.ts via @agentbuilder/observability
# `runCron` and (b) listed in the agent's `crons[]` array in the registry.
# [triggers]
# crons = ["0 7 * * *"]

# Document every secret this Worker reads from `env.X` and mirror the list
# into `secrets[]` on the registry entry — the dashboard uses it to tell
# operators what to `wrangler secret put` before deploy.
#   wrangler secret put ANTHROPIC_API_KEY  --name __AGENT_ID__
#   wrangler secret put MCP_HTTP_KEY       --name __AGENT_ID__
#   wrangler secret put WEB_UI_PASSWORD    --name __AGENT_ID__
#   wrangler secret put EXTERNAL_API_KEY   --name __AGENT_ID__
