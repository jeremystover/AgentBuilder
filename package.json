{
  "name": "agentbuilder",
  "version": "0.0.1",
  "private": true,
  "description": "A meta-agent that builds, deploys, and manages a fleet of specialized agents on Cloudflare.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "deploy": "turbo run deploy",
    "typecheck": "turbo run typecheck",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "create-agent": "tsx tools/create-agent.ts",
    "fleet:setup-secrets": "bash tools/setup-fleet-secrets.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20260415.1",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "wrangler": "^4.83.0"
  }
}
