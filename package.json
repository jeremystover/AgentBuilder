{
  "name": "booking-sync",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted booking channel manager for short-term rentals. Keeps Airbnb, VRBO, Booking.com and your direct site in sync. Runs on Cloudflare Workers.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute booking_sync --file=./schema.sql",
    "db:init:local": "wrangler d1 execute booking_sync --local --file=./schema.sql",
    "db:seed": "wrangler d1 execute booking_sync --file=./seed.sql",
    "db:seed:local": "wrangler d1 execute booking_sync --local --file=./seed.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.80.0"
  }
}
